<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="initial-schema-purchase-status-1" author="virtadity">
        <createTable tableName="purchase_status">
            <column name="purchase_status_id" type="uuid"/>
            <column name="purchase_status_name" type="varchar(255)" />
            <column name="purchase_status_description" type="text"/>
        </createTable>
    </changeSet>

    <changeSet id="initial-schema-purchase-status-2" author="virtadity">
        <addNotNullConstraint tableName="purchase_status" columnName="purchase_status_id"/>
    </changeSet>

    <changeSet id="initial-schema-purchase-status-3" author="virtadity">
        <addNotNullConstraint tableName="purchase_status" columnName="purchase_status_name"/>
    </changeSet>

    <changeSet id="initial-schema-purchase-status-4" author="virtadity">
        <addNotNullConstraint tableName="purchase_status" columnName="purchase_status_description"/>
    </changeSet>

    <changeSet id="initial-schema-purchase-status-5" author="virtadity">
        <addPrimaryKey tableName="purchase_status" columnNames="purchase_status_id"/>
    </changeSet>

    <changeSet id="initial-schema-purchase-status-6" author="virtadity">
        <addUniqueConstraint tableName="purchase_status" columnNames="purchase_status_name"/>
    </changeSet>

    <changeSet id="initial-schema-purchase-status-7" author="virtadity">
        <createIndex tableName="purchase_status" indexName="purchase_status_name_index">
            <column name="purchase_status_name"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>